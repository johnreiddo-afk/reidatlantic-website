{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/content/**",
              "components/forms/**",
              "components/marketing/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Inter|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Inter, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnnouncementBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|linkLabel|href|onClose|style|key|ref|className|style|children)$/]",
        "message": "<AnnouncementBar> doesn't accept that prop. Declared props: children, linkLabel, href, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:coral|outline|neutral|dark|blue)$/]",
        "message": "<Badge> variant must be one of 'coral' | 'outline' | 'neutral' | 'dark' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|disabled|iconRight|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, disabled, iconRight, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|inverse|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'inverse' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|surface|radius|bordered|pad|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, surface, radius, bordered, pad, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:white|stone|dark|green|navy|media)$/]",
        "message": "<Card> surface must be one of 'white' | 'stone' | 'dark' | 'green' | 'navy' | 'media'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Card> radius must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|type|placeholder|value|onChange|required|onDark|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, id, type, placeholder, value, onChange, required, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MonoLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dot|color|style|key|ref|className|style|children)$/]",
        "message": "<MonoLabel> doesn't accept that prop. Declared props: children, dot, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillOutline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|count|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PillOutline> doesn't accept that prop. Declared props: children, active, count, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustLogoStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:caption|logos|onDark|style|key|ref|className|style|children)$/]",
        "message": "<TrustLogoStrip> doesn't accept that prop. Declared props: caption, logos, onDark, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
